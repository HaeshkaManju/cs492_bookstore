# password_utils.py
import hashlib
import os
import hmac


def hash_password(password: str) -> str:
    """
    Hashes a user password using SHA-256 with a random salt.
    Returns the salt and hashed password together.
    """
    salt = os.urandom(16)
    password_hash = hashlib.pbkdf2_hmac(
        "sha256",
        password.encode("utf-8"),
        salt,
        100000
    )

    return salt.hex() + ":" + password_hash.hex()


def verify_password(stored_password: str, entered_password: str) -> bool:
    """
    Verifies an entered password against the stored hashed password.
    """
    salt_hex, stored_hash_hex = stored_password.split(":")

    salt = bytes.fromhex(salt_hex)
    stored_hash = bytes.fromhex(stored_hash_hex)

    entered_hash = hashlib.pbkdf2_hmac(
        "sha256",
        entered_password.encode("utf-8"),
        salt,
        100000
    )

    return hmac.compare_digest(stored_hash, entered_hash)
