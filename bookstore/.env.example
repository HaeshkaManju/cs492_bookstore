# =============================================================================
# Bookstore Inventory Management System - Environment Configuration
# =============================================================================
# 
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# IMPORTANT: Never commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Flask Configuration
# -----------------------------------------------------------------------------

# Application entry point
FLASK_APP=run.py

# Environment: development, testing, or production
FLASK_ENV=development

# Host and port for development server
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Secret key for session encryption and CSRF tokens
# In production, use a strong random string (e.g., output of: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=dev-secret-key-change-in-production

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------

# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://bookstore:bookstore_dev@localhost:5432/bookstore_dev

# Individual components (used if DATABASE_URL not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bookstore_dev
DB_USER=bookstore
DB_PASSWORD=bookstore_dev

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------

# Bcrypt hashing rounds (4 for development, 12 for production)
# Higher = more secure but slower
BCRYPT_LOG_ROUNDS=4

# Session lifetime in minutes
SESSION_LIFETIME_MINUTES=60

# -----------------------------------------------------------------------------
# Email Configuration (for notifications - Phase 6)
# -----------------------------------------------------------------------------

# MAIL_SERVER=smtp.example.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_DEFAULT_SENDER=noreply@bookstore.example.com

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------

# Items per page for pagination
ITEMS_PER_PAGE=20

# Invoice number prefix
INVOICE_NUMBER_PREFIX=INV

# Default payment terms for invoices
DEFAULT_PAYMENT_TERMS=Net 30

# Book request expiry (days)
REQUEST_EXPIRY_DAYS=365
